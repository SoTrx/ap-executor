# REDIS instance
REDIS_BROKER_URI=redis://redis:6379/0

# Set to 'false' to disable the embedded Celery worker (use when running standalone workers)
USE_EMBEDDED_CELERY_WORKER=true

# Primary PostgreSQL Server
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Timescale/Secondary PostgreSQL Server (Optional)
# If a database is not found on the primary server, the service will try the Timescale server
# POSTGRES_TIMESCALE_HOST=localhost
# POSTGRES_TIMESCALE_PORT=5433

# API Configuration
# ROOT_PATH is used when the API is behind a reverse proxy
# ROOT_PATH=
